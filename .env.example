PORT=3000
JWT_SECRET=troque-esta-chave-em-producao

# Banco PostgreSQL gratuito:
# 1. Crie um projeto em Supabase, Neon ou Railway.
# 2. Copie a connection string PostgreSQL.
# 3. No Supabase, se aparecer "Not IPv4 compatible", use a string do Session Pooler.
# 4. Cole abaixo e rode database/schema.sql + database/seed.sql.
DATABASE_URL=postgresql://usuario:senha@host:5432/database?sslmode=require
